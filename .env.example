# PostgreSQL connection string
MCP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/explorer

# Anthropic API key for natural language → SQL translation
MCP_ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-sonnet-4-20250514)
MCP_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Query execution timeout in seconds (default: 10)
MCP_QUERY_TIMEOUT_SECONDS=10

# Maximum rows returned per query (default: 100)
MCP_MAX_ROWS=100
